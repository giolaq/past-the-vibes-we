    { "capability": "install", "command": ["replay", "install", "build/aarch64-debug/pocket-cinema_aarch64.vpkg"], "code": 0, "stdout": "Installing/Updating pocket-cinema_aarch64.vpkg .. success\n", "stderr": "" },
    { "capability": "launch", "command": ["replay", "launch", "com.tvbuild.pocketcinema.main"], "code": 0, "stdout": "Launching app com.tvbuild.pocketcinema.main .. success\n", "stderr": "" },
    { "capability": "logs", "command": ["replay", "logs"], "code": 0, "stdout": "Pocket Cinema started\nInitial focus: featured-action\n", "stderr": "" },
    { "capability": "capture", "command": ["replay", "capture", "/tmp/tv-build-launch.png"], "code": 0, "stdout": "Saved /tmp/tv-build-launch.png\n", "stderr": "" },
    { "capability": "pull", "command": ["replay", "pull", "/tmp/tv-build-launch.png", "01-launch.png"], "code": 0, "stdout": "Transferred /tmp/tv-build-launch.png\n", "stderr": "" }
  ],
  "checks": [
    {
      "name": "focus transition suite",
