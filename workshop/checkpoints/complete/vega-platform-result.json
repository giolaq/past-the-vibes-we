{
  "schemaVersion": 1,
  "evidenceMode": "replay",
  "sdkVersion": "0.22.5875",
  "adbtPackage": "@amazon-devices/amazon-devices-buildertools-mcp@1.0.5",
  "appId": "com.tvbuild.pocketcinema.main",
  "packagePath": "build/aarch64-debug/pocket-cinema_aarch64.vpkg",
  "steps": [
    { "capability": "sdk_version", "command": ["replay", "sdk_version"], "code": 0, "stdout": "0.22.5875\n", "stderr": "" },
    { "capability": "device_status", "command": ["replay", "device_status"], "code": 0, "stdout": "List of devices attached\nemulator-5554 device product:VegaVirtualDevice\n", "stderr": "" },
